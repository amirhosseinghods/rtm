{"text":"## ETHUSDT вҖ” ШӘШ§ЫҢЩ…вҖҢЩҒШұЫҢЩ… M5\nЩӮЫҢЩ…ШӘЩҗ Щ„ШӯШёЩҮвҖҢШ§ЫҢ: **1,562.55**\nШіЩҲЪҜЫҢШұЫҢЩҗ ШЁШ§ШІШ§Шұ (H1+H4+Daily): **ЩҶШІЩҲЩ„ЫҢ** вҖ” ЩӮЫҢЩ…ШӘ ШҜШұ ЩҶШ§ШӯЫҢЩҮЩ” **ШӘШ®ЩҒЫҢЩҒ (Discount)**.\nЩҲШ¶Ш№ЫҢШӘЩҗ Ш§ЫҢЩҶ ШӘШ§ЫҢЩ…вҖҢЩҒШұЫҢЩ…: _Ш§Ш¬ Ш§Ш«ШЁШ§ШӘвҖҢШҙШҜЩҮ (ШЁЪ©вҖҢШӘШіШӘЩҗ OOS-ЩҫШ§ЫҢШҜШ§Шұ)_\n\n## Ш§ЩӮШҜШ§Щ…Щҗ Ш§Щ„Ш§ЩҶ вҖ” ШўЩ…Ш§ШҜЩҮЩ” ЩҒШұЩҲШҙ\nШ§Щ„Ш§ЩҶ ЩӮЫҢЩ…ШӘ ШҜШ§Ш®Щ„/Ъ©ЩҶШ§ШұЩҗ ЩҶШ§ШӯЫҢЩҮЩ” ЩҒШұЩҲШҙ Ш§ШіШӘ вҖ” ШўЩ…Ш§ШҜЩҮЩ” ЩҲШұЩҲШҜ. ЩҲШұЩҲШҜ ~1560.33ШҢ Ш§ШіШӘШ§Щҫ 1584.009588. ШЁШұЩҶШ§Щ…ЩҮЩ” Ш®ШұЩҲШ¬Щҗ ЩҫЩ„ЩҮвҖҢШ§ЫҢ: 1/3 ШҜШұ 1548.490206 (~0.5R)ШҢ Ш§ШіШӘШ§Щҫ ШЁЩҮ ЩҶЩӮШ·ЩҮЩ” ШіШұШЁЩҮвҖҢШіШұШҢ ШЁЩӮЫҢЩҮ ШӘШ§ 1512.970824 (~2.0R). ШұЫҢШіЪ©Щҗ Ш§ЫҢЩҶ ЩҶШ§ШӯЫҢЩҮ: Ъ©Щ…. Ш§ЩҲЩ„ ШӘШЈЫҢЫҢШҜЫҢЩҮЩ” Ъ©ЩҶШҜЩ„ЫҢ ШЁЪҜЫҢШұ.\nвҖў ШҜШ§Щ…ЫҢЩҶЩҶШіЩҗ ШӘШӘШұ: **8.7ЩӘ** (ШұЩҲЩҶШҜ ЩҶШ§Щ…ШҙШ®Шө) вҖ” ШӘШ§ШұЫҢШ®ЪҶЩҮЩ” ШҜШ§Щ…ЫҢЩҶЩҶШі ЩҮЩҶЩҲШІ Ъ©Ш§ЩҒЫҢ ЩҶЫҢШіШӘ (ШЁШ§ ЩҮШұ ШЁШұЩҲШІШұШіШ§ЩҶЫҢ Ъ©Ш§Щ…Щ„вҖҢШӘШұ Щ…ЫҢвҖҢШҙЩҲШҜ).\n\n## ШЁЩҮШӘШұЫҢЩҶ ШіШӘШ§Щҫ вҖ” ЩҒШұЩҲШҙ (SHORT)\nвҖў Щ…ЩҶШЁШ№Щҗ ЩҶШ§ШӯЫҢЩҮ: Ш§ЩҲШұШҜШұШЁЩ„Ш§Ъ©Щҗ 1ШіШ§Ш№ШӘЩҮ (HTF вҖ” Ш§Ш¬ Ш§Ш«ШЁШ§ШӘвҖҢШҙШҜЩҮ) | Ъ©ЫҢЩҒЫҢШӘ(grade): 2/2\nвҖў Щ…ШӯШҜЩҲШҜЩҮЩ” ЩҶШ§ШӯЫҢЩҮ: 1,560.33 ШӘШ§ 1,583.09\nвҖў Ш§Ш№ШӘЩ…Ш§ШҜЩҗ ШіЫҢШіШӘЩ…: **ШЁШ§Щ„Ш§** вҖ” ЩҮЩ…вҖҢШ¬ЩҮШӘ ШЁШ§ ШұЩҲЩҶШҜ\nвҖў ШұЫҢШіЪ©Щҗ Ш§ЫҢЩҶ ЩҶШ§ШӯЫҢЩҮ: **Ъ©Щ…**\nвҖў ШӘЩ„ЩҒЫҢЩӮЩҗ ШіШЁЪ©вҖҢЩҮШ§: **0/3** ШіШЁЪ© ЩҮЩ…вҖҢШ¬ЩҮШӘвҖҢШ§ЩҶШҜ (вҖ”) вҖ” ШҜЩӮШӘЩҗ ШўЩ…ЩҲШ®ШӘЩҮвҖҢШҙШҜЩҮ ШЁШ§ вүҘ0 ШіШЁЪ©Щҗ ЩҮЩ…вҖҢШ¬ЩҮШӘ: **47ЩӘ** (ШұЩҲЫҢ 15875 ЩҶЩ…ЩҲЩҶЩҮ)\nвҖў Ш§ШІ Ш§ШіШӘШ§ЩҫвҖҢЩҮШ§ЫҢ ЪҜШ°ШҙШӘЩҮ: ЩҶШ§ШӯЫҢЩҮвҖҢЩҮШ§ЫҢЫҢ ШҙШЁЫҢЩҮЩҗ Ш§ЫҢЩҶ **79.7ЩӘ** Ш§ШіШӘШ§Щҫ Ш®ЩҲШұШҜЩҮвҖҢШ§ЩҶШҜ (ШұЩҲЫҢ 345 ШіШӘШ§ЩҫШҢ ШЁШ§ШІШҜЩҮЩҗ Щ…ЫҢШ§ЩҶЪҜЫҢЩҶ -0.391R).\nвҖў ЪҶШұШ§ Ш§ЫҢЩҶ ЩҶШ§ШӯЫҢЩҮ: ЩҶШ§ШӯЫҢЩҮЩ” 1ШіШ§Ш№ШӘЩҮ Ш§ШіШӘ (ШӘЩҶЩҮШ§ Щ…ЩҶШЁШ№ЫҢ Ъ©ЩҮ ШҜШұ ШЁЪ©вҖҢШӘШіШӘЩҗ OOS Ш§Ш¬ ШҜШ§ШҙШӘ)Шӣ grade 2 = Ш§ЫҢЩ…ЩҫШ§Щ„ШіЩҗ ЩӮЩҲЫҢ + ЪҜЩҫ/FTR ШЁШ№ШҜ Ш§ШІ ШӘШҙЪ©ЫҢЩ„Шӣ ЩҮЩ…вҖҢШ¬ЩҮШӘ ШЁШ§ ШіЩҲЪҜЫҢШұЫҢЩҗ HTF.\nвҖў ШӘШЈЫҢЫҢШҜЩҮШ§ЫҢ Ъ©Щ…Ъ©ЫҢЩҗ RTM (ЩҶЩ…Ш§ЫҢШҙЫҢШҢ ЩҶЩҮ ЪҜЫҢШӘЩҗ ШіЫҢЪҜЩҶШ§Щ„): Ъ©ЩҶШҜЩ„Щҗ Ш§ЩҗЩҶЪҜШ§Щ„ЩҒЩҗ ЩҶШІЩҲЩ„ЫҢ (ЩҲШ§Ъ©ЩҶШҙЩҗ ЩҒШұЩҲШҙЩҶШҜЪҜШ§ЩҶ)ШҢ Ъ©ЩҶШҜЩ„Щҗ ЩҫЫҢЩҶвҖҢШЁШ§ШұЩҗ ЩҶШІЩҲЩ„ЫҢ (ШіШ§ЫҢЩҮЩ” ШЁШ§Щ„Ш§ЫҢЫҢЩҗ ШЁЩ„ЩҶШҜ).\nвҖў ЩӮЫҢЩ…ШӘ ЩҮЩ…ЫҢЩҶ ШӯШ§Щ„Ш§ ЩҶШІШҜЫҢЪ©Щҗ ЩҶШ§ШӯЫҢЩҮ Ш§ШіШӘ (0.72 ATR) вҖ” ШўЩ…Ш§ШҜЩҮвҖҢШЁШ§Шҙ.\n\n## ЩҫЩ„ЩҶЩҗ Щ…Ш№Ш§Щ…Щ„ЩҮ вҖ” Щ…ШҜЩ„Щҗ R-grid (Ш§Ш№ШӘШЁШ§ШұШіЩҶШ¬ЫҢвҖҢШҙШҜЩҮ)\nвҖў ЩҲШұЩҲШҜ (Щ„ШЁЩҮЩ” ЩҫШұЩҲЪҜШІЫҢЩ…Ш§Щ„): **1,560.33**\nвҖў Ш§ШіШӘШ§ЩҫвҖҢЩ„Ш§Ші: **1,584.01**  (ШұЫҢШіЪ© вүҲ 23.6796)\nвҖў Ш§ЩҮШҜШ§ЩҒ: TP1 1,536.65 (1R) | TP2 **1,512.97 (2R вҶҗ Ш®ШұЩҲШ¬Щҗ Ш§ШөЩ„ЫҢ)** | TP3 1,489.29 (3R)\nвҖў ЩҫЫҢШҙЩҶЩҮШ§ШҜЩҗ Щ…ШҜЫҢШұЫҢШӘ: ШӯШҜЩҗ Ш¶ШұШұ ШұШ§ ЩҫШі Ш§ШІ TP1 ШЁЩҮ ЩҶЩӮШ·ЩҮЩ” ШіШұШЁЩҮвҖҢШіШұ ШЁШЁШұШӣ Ш®ШұЩҲШ¬Щҗ Ш§ШөЩ„ЫҢ ШұЩҲЫҢ TP2 (2R).\n\n## ШӘШЈЫҢЫҢШҜЫҢЩҮвҖҢЩҮШ§ЫҢ ЩҫЫҢШҙ Ш§ШІ ЩҲШұЩҲШҜ (ШӘЩҲШөЫҢЩҮЩ” RTM)\n1) ЩӮЫҢЩ…ШӘ ЩҲШ§ЩӮШ№Ш§ЩӢ ШЁЩҮ ЩҶШ§ШӯЫҢЩҮ ЩҲШ§Ъ©ЩҶШҙ ЩҶШҙШ§ЩҶ ШҜЩҮШҜ (Ъ©ЩҶШҜЩ„Щҗ Ш§ЩҗЩҶЪҜШ§Щ„ЩҒ/ЩҫЫҢЩҶвҖҢШЁШ§ШұЩҗ ЩҶШІЩҲЩ„ЫҢ ШҜШ§Ш®Щ„Щҗ ЩҶШ§ШӯЫҢЩҮ).\n2) ШіШҙЩҶ Щ…ЩҶШ§ШіШЁ ШЁШ§ШҙШҜ (Ъ©ШұЫҢЩҫШӘЩҲ: ЩҶЫҢЩҲЫҢЩҲШұЪ©Шӣ Ш·Щ„Ш§: Щ„ЩҶШҜЩҶ).\n3) ЩҒШ¶Ш§ЫҢ ШӯШҜШ§ЩӮЩ„ 2R ШӘШ§ ЩҶШ§ШӯЫҢЩҮЩ” Щ…ЩӮШ§ШЁЩ„ ШЁШ§ШІ ШЁШ§ШҙШҜ (room).\n4) Ш®Щ„Ш§ЩҒЩҗ Ш§ЫҢЩ…ЩҫШ§Щ„ШіЩҗ Ш®ЫҢЩ„ЫҢ ШӘЩҶШҜЩҗ HTF ЩҲШ§ШұШҜ ЩҶШҙЩҲ (ЩҶШҙШ§ЩҶЩҮЩ” ШҙЪ©ШіШӘЩҗ ЩҶШ§ШӯЫҢЩҮ).\n\n## ШҜЫҢШҜЩҗ ШӘЪ©Щ…ЫҢЩ„ЫҢ вҖ” RSI ЩҲ ШұЩҲЩҶШҜ\nвҖў RSI(14) = **33.7** вҖ” Ш®ЩҶШ«ЫҢ.\n  (ЩҶЪ©ШӘЩҮ: RSI ЩҲ ЩҲШ§ЪҜШұШ§ЫҢЫҢ ШҜШұ ШӘШ§ЫҢЩ…вҖҢЩҒШұЫҢЩ…вҖҢЩҮШ§ЫҢ ШЁШ§Щ„Ш§ШӘШұ вҖ” 15Щ…/1ШіШ§Ш№ШӘЩҮ/4ШіШ§Ш№ШӘЩҮ/ШұЩҲШІШ§ЩҶЩҮ вҖ” Щ…Ш№ШӘШЁШұШӘШұЩҶШҜ.)\nвҖў ШўШ®ШұЫҢЩҶ ЩҲШ§ЪҜШұШ§ЫҢЫҢ: **ЩҲШ§ЪҜШұШ§ЫҢЫҢЩҗ ШөШ№ЩҲШҜЫҢ (RSI) вҖ” Ъ©ЩҒЩҗ ЩҫШ§ЫҢЫҢЩҶвҖҢШӘШұ Ш§Щ…Ш§ RSI ШЁШ§Щ„Ш§ШӘШұ** (RSI=53.7). ЩҲШ§ЪҜШұШ§ЫҢЫҢ ЩҶШҙШ§ЩҶЩҮЩ” Ш¶Ш№ЩҒЩҗ ШұЩҲЩҶШҜЩҗ ЩҒШ№Щ„ЫҢ Ш§ШіШӘ вҖ” ШӘШЈЫҢЫҢШҜЩҗ Ъ©Щ…Ъ©ЫҢШҢ ЩҶЩҮ ШіЫҢЪҜЩҶШ§Щ„Щҗ Щ…ШіШӘЩӮЩ„.\nвҖў ЩҫЫҢШҙвҖҢШЁЫҢЩҶЫҢЩҗ Ш¬ЩҮШӘ: **ШЁШҜЩҲЩҶЩҗ ШіЩҲЪҜЫҢШұЫҢЩҗ Щ…Ш·Щ…ШҰЩҶ** вҖ” Щ…ШҜЩ„ ШҜШұ Ш§ЫҢЩҶ Щ„ШӯШёЩҮ Щ„ШЁЩҮЩ” Ш¬ЩҮШӘЫҢЩҗ Ъ©Ш§ЩҒЫҢ ЩҶЩ…ЫҢвҖҢШЁЫҢЩҶШҜ ЩҲ ШўЪҜШ§ЩҮШ§ЩҶЩҮ Ш§ШІ ЩҫЫҢШҙвҖҢШЁЫҢЩҶЫҢ ЩҫШұЩҮЫҢШІ Щ…ЫҢвҖҢЪ©ЩҶШҜ (ШөШЁШұШӣ ШҜЩӮШӘЩҗ ШіЫҢШіШӘЩ… ЩҲЩӮШӘЫҢ ЩҫЫҢШҙвҖҢШЁЫҢЩҶЫҢ Щ…ЫҢвҖҢЪ©ЩҶШҜ ШЁШ§Щ„Ш§ШӘШұ Ш§ШіШӘ).\n  ШҜЩ„Ш§ЫҢЩ„: ШіЩҲЪҜЫҢШұЫҢЩҗ HTF (Щ…Ш®Ш§Щ„ЩҒ)Шӣ ШіШӘШ§ЩҫЩҗ ЩҒШ№Ш§Щ„ (Щ…Ш®Ш§Щ„ЩҒ).\n  ШіЩҶШ§ШұЫҢЩҲ: Щ…ШіЫҢШұЩҗ Ъ©Щ„ЫҢ Ш®ЩҶШ«ЫҢ/ШұЩҶШ¬. ШҜШұ Ш§ЫҢЩҶ ШЁШ§ШІЩҮ ШЁЩҮ ЩҶШ§ШӯЫҢЩҮЩ” Щ…Ш®Ш§Щ„ЩҒЩҗ Щ…ШҙШ®ШөЫҢ ЩҶЩ…ЫҢвҖҢШұШіШҜ.\n  ШҜЩӮШӘЩҗ ЩҫЫҢШҙвҖҢШЁЫҢЩҶЫҢвҖҢЩҮШ§ЫҢ ЪҜШ°ШҙШӘЩҮЩ” ШіЫҢШіШӘЩ… ШұЩҲЫҢ Ш§ЫҢЩҶ ЩҶЩ…Ш§ШҜ/ШӘШ§ЫҢЩ…вҖҢЩҒШұЫҢЩ…: ~48ЩӘ (ШұЩҲЫҢ 1287 ЩҫЫҢШҙвҖҢШЁЫҢЩҶЫҢЩҗ ШЁШіШӘЩҮвҖҢШҙШҜЩҮ).\n  Ш®Ш·Щҗ ЩҶЩӮШ·ЩҮвҖҢЪҶЫҢЩҶЩҗ ШұЩҲЫҢ ЪҶШ§ШұШӘ ЩҒЩӮШ· Щ…ШіЫҢШұЩҗ Щ…ШӯШӘЩ…Щ„ Ш§ШіШӘШӣ Щ…Ш№ЫҢШ§ШұЩҗ ЩҲШұЩҲШҜ ЩҮЩ…Ш§ЩҶ ЩҫЩ„ЩҶЩҗ ЩҶШ§ШӯЫҢЩҮвҖҢШ§ЫҢ ШЁШ§Щ„Ш§ШіШӘ.\n\nвҖ”вҖ”вҖ”\nвҡ пёҸ Ш§ЫҢЩҶ ЫҢЪ© **ШӘШӯЩ„ЫҢЩ„Щҗ ШіЫҢШіШӘЩ…ЫҢ** Ш§ШіШӘШҢ ЩҶЩҮ ШіЩҒШ§ШұШҙ. ЩҮЫҢЪҶ Щ…Ш№Ш§Щ…Щ„ЩҮвҖҢШ§ЫҢ ШЁЩҮвҖҢШ¬Ш§ЫҢ ШӘЩҲ Ш§Ш¬ШұШ§ ЩҶЩ…ЫҢвҖҢШҙЩҲШҜ вҖ” ЩҲШұЩҲШҜ/Ш®ШұЩҲШ¬ ШұШ§ Ш®ЩҲШҜШӘ ШҜШіШӘЫҢ Ш§ЩҶШ¬Ш§Щ… Щ…ЫҢвҖҢШҜЩҮЫҢ. ШұЫҢШіЪ©Щҗ ЩҮШұ Щ…Ш№Ш§Щ…Щ„ЩҮ ШұШ§ 1ЩӘ ЩҶЪҜЩҮ ШҜШ§Шұ.","signal":{"symbol":"ETHUSDT","tf":"M5","price":1562.55,"atr":3.065294,"bias":"ЩҶШІЩҲЩ„ЫҢ","bias_val":-1,"discount":true,"premium":false,"gold":false,"tf_health":{"color":"green","note":"Ш§Ш¬ Ш§Ш«ШЁШ§ШӘвҖҢШҙШҜЩҮ (ШЁЪ©вҖҢШӘШіШӘЩҗ OOS-ЩҫШ§ЫҢШҜШ§Шұ)"},"zones":[{"kind":"supply","dir":"SHORT","src":"OB-1h","top":1583.09,"bot":1560.33,"grade":2,"entry":1560.33,"sl":1584.009588,"tp1":1536.650412,"tp2":1512.970824,"tp3":1489.291235,"risk":23.679588,"partial":{"scale_R":0.5,"scale_frac":0.3333,"scale_price":1548.490206,"move_be":true,"be_price":1560.33,"runner_R":2.0,"runner_tp":1512.970824,"full_R":1.5},"dist_atr":0.72,"room_R":null,"with_trend":true,"confidence":"HIGH","confluence":[{"key":"engulf","fa":"Ъ©ЩҶШҜЩ„Щҗ Ш§ЩҗЩҶЪҜШ§Щ„ЩҒЩҗ ЩҶШІЩҲЩ„ЫҢ (ЩҲШ§Ъ©ЩҶШҙЩҗ ЩҒШұЩҲШҙЩҶШҜЪҜШ§ЩҶ)"},{"key":"pin","fa":"Ъ©ЩҶШҜЩ„Щҗ ЩҫЫҢЩҶвҖҢШЁШ§ШұЩҗ ЩҶШІЩҲЩ„ЫҢ (ШіШ§ЫҢЩҮЩ” ШЁШ§Щ„Ш§ЫҢЫҢЩҗ ШЁЩ„ЩҶШҜ)"}],"disc":null,"prem":false,"model_p_up":0.4985,"model_agree":false,"model_against":false,"model_gate":"neutral","action":"SELL","action_fa":"ЩҒШұЩҲШҙ","actionable_now":true,"combo_score":0,"combo_styles":[],"combo_confirmed":false,"setup_type":"trend","risk_rating":{"level":"Ъ©Щ…","score":0,"reasons":[]},"combo_learned_rate":0.47,"combo_l